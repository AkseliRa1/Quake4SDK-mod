{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Quake 4 Debug",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "D:/SteamLibrary/steamapps/common/Quake 4/Quake4.exe",
            //The args must not have spaces in them. If you need a space split them.
            "args": [
            "+set","fs_game",
            "xanzcoop",
            "+set","com_allowConsole",
            "1",
            "+set","win_allowmultipleInstances",
            "1",
            "+disconnect",
            "+set","developer",
            "1",
            "+set","si_pure",
            "0",
            "+set","logfile",
            "2",
            "+set","fs_savepath",
            "D:/SteamLibrary/steamapps/common/Quake 4/host/",
            "+set","si_map",
            "game/pukke",
            "+spawnserver",
            "+set","si_gameType",
            "co-op",

            ],
            "stopAtEntry": false,
            "cwd": "D:/SteamLibrary/steamapps/common/Quake 4",
            "environment": []
        }
    ]
}